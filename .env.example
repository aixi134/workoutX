# PostgreSQL for local commands on the host.
# docker-compose.yml overrides this inside the app container to use postgres:5432.
DATABASE_URL="postgresql://workoutx:workoutx@localhost:5432/workoutx?schema=public"

# WorkoutX API (server-side only)
WORKOUTX_API_KEY="wx_your_key_here"
WORKOUTX_API_BASE_URL="https://api.workoutxapp.com/v1"

# AI provider. Use "mock" for local UI testing without API calls.
AI_PROVIDER="openai"
OPENAI_API_KEY="sk-your-key-here"
# Optional: OpenAI-compatible endpoint. Keep empty to use the official OpenAI API.
# Example: OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-5.5"
# Keep UI/API usable when OpenAI-compatible upstream is unavailable. Set false to fail hard.
AI_FALLBACK_TO_MOCK="true"

# Optional: tune cache lifetime in hours.
QUERY_CACHE_TTL_HOURS="24"

# Optional: set this only when deploying behind a sub-path, e.g. https://example.com/workoutx.
# After changing it, rebuild/redeploy the Next.js app.
NEXT_PUBLIC_BASE_PATH=""
